{
  "name": "choreography",
  "version": "0.0.1",
  "description": "Family chore tracking and rewards app built with SvelteKit.",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sullyTheDev/choreography.git"
  },
  "bugs": {
    "url": "https://github.com/sullyTheDev/choreography/issues"
  },
  "homepage": "https://github.com/sullyTheDev/choreography#readme",
  "keywords": [
    "sveltekit",
    "family",
    "chores",
    "rewards",
    "sqlite",
    "drizzle"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:host": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "svelte-check --tsconfig ./tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "node src/migrate.mjs",
    "db:seed": "tsx src/lib/server/db/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@lucide/svelte": "^1.7.0",
    "@opentelemetry/api": "^1.9.1",
    "@skeletonlabs/skeleton": "^4.15.1",
    "@skeletonlabs/skeleton-svelte": "^4.15.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.2",
    "bcrypt": "^5.1.1",
    "better-auth": "^1.6.5",
    "canvas-confetti": "^1.9.4",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.40.0",
    "pino": "^9.3.2",
    "swagger-ui-dist": "^5.32.4",
    "tailwindcss": "^4.2.2",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@iconify/svelte": "^4.2.0",
    "@playwright/test": "^1.48.0",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.8.0",
    "@types/bcrypt": "^5.0.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.17.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.1.3",
    "svelte": "^5.7.0",
    "svelte-check": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
